{
  "name": "flipkart-clone-backend",
  "version": "1.0.0",
  "description": "Flipkart Clone Backend - REST API with Node.js, Express, Prisma, and PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "npx prisma migrate dev",
    "migrate:prod": "npx prisma migrate deploy",
    "generate": "npx prisma generate",
    "seed": "node prisma/seed.js",
    "seed:enterprise": "node prisma/seed_enterprise.js",
    "data:scrape": "node scripts/scrapeRealData.js",
    "studio": "npx prisma studio"
  },
  "prisma": {
    "seed": "node prisma/seed_enterprise.js"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.11"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.10.2"
  }
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id        String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name      String?
  email     String?    @unique
  password  String?
  phone     String?    @unique
  address   String?
  avatarUrl String?
  createdAt DateTime   @default(now()) @map("created_at")
  addresses Address[]
  cart      Cart?
  orders    Order[]
  reviews   Review[]
  wishlist  Wishlist[]

  @@map("profiles")
}

model Address {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  fullName     String   @map("full_name")
  phone        String
  addressLine1 String   @map("address_line1")
  addressLine2 String?  @map("address_line2")
  city         String
  state        String
  postalCode   String   @map("postal_code")
  country      String   @default("India")
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")
  user         Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@index([userId])
  @@map("addresses")
}

model Category {
  name      String    @unique
  slug      String    @unique
  imageUrl  String?
  createdAt DateTime  @default(now()) @map("created_at")
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  products  Product[]

  @@index([slug])
  @@map("categories")
}

model Product {
  title          String
  description    String?
  price          Decimal        @db.Decimal(10, 2)
  discountPrice  Decimal?       @db.Decimal(10, 2)
  discountPct    Int            @default(0)
  stock          Int            @default(0)
  rating         Float          @default(0)
  reviewCount    Int            @default(0)
  brand          String?
  isFeatured     Boolean        @default(false)
  categoryId     String         @map("category_id") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at")
  thumbnail      String?
  updatedAt      DateTime       @updatedAt @map("updated_at")
  id             String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  specifications Json?          @default("{}")
  cartItems      CartItem[]
  orderItems     OrderItem[]
  images         ProductImage[]
  category       Category       @relation(fields: [categoryId], references: [id])
  reviews        Review[]
  wishlists      Wishlist[]

  @@index([categoryId])
  @@index([title])
  @@index([price])
  @@map("products")
}

model ProductImage {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  imageUrl     String   @map("image_url")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model Cart {
  createdAt DateTime   @default(now()) @map("created_at")
  userId    String     @unique @map("user_id") @db.Uuid
  id        String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  items     CartItem[]
  user      Profile    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("carts")
}

model CartItem {
  quantity  Int      @default(1)
  cartId    String   @map("cart_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  productId String   @map("product_id") @db.Uuid
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
  @@map("cart_items")
}

model Order {
  status          OrderStatus @default(PLACED)
  addressId       String?     @map("address_id") @db.Uuid
  createdAt       DateTime    @default(now()) @map("created_at")
  discountAmount  Decimal     @default(0) @map("discount_amount") @db.Decimal(10, 2)
  finalAmount     Decimal     @map("final_amount") @db.Decimal(10, 2)
  paymentMethod   String      @default("COD") @map("payment_method")
  shippingAddress String      @map("shipping_address")
  shippingCity    String      @map("shipping_city")
  shippingName    String      @map("shipping_name")
  shippingPhone   String      @map("shipping_phone")
  shippingState   String      @map("shipping_state")
  shippingZip     String      @map("shipping_zip")
  totalAmount     Decimal     @map("total_amount") @db.Decimal(10, 2)
  userId          String      @map("user_id") @db.Uuid
  id              String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  items           OrderItem[]
  address         Address?    @relation(fields: [addressId], references: [id])
  user            Profile     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  quantity        Int
  title           String?
  orderId         String   @map("order_id") @db.Uuid
  priceAtPurchase Decimal  @map("price_at_purchase") @db.Decimal(10, 2)
  productId       String?  @map("product_id") @db.Uuid
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model Wishlist {
  createdAt DateTime @default(now()) @map("created_at")
  productId String   @map("product_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlists")
}

model Review {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
  @@map("reviews")
}

enum OrderStatus {
  PLACED
  SHIPPED
  DELIVERED
  CANCELLED
}
